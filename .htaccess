Options -Indexes
DirectoryIndex index.html
AddDefaultCharset UTF-8
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^trainingszeiten-2/?$ /#training [R=301,L,NE]
  RewriteRule ^kontakt/?$ /#kontakt [R=301,L,NE]
  RewriteRule ^anfahrt/?$ /#anfahrt [R=301,L,NE]
  RewriteRule ^ansprechpartner/?$ /#kontakt [R=301,L,NE]
  RewriteRule ^impressum/?$ /impressum.html [R=301,L]
  RewriteRule ^datenschutz/?$ /datenschutz.html [R=301,L]
  RewriteRule ^datenschutzerklaerung/?$ /datenschutz.html [R=301,L]
  RewriteRule ^datenschutzerklarung/?$ /datenschutz.html [R=301,L]
  RewriteRule ^privacy-policy/?$ /datenschutz.html [R=301,L]
  RewriteRule ^mannschaften/?$ /#teams [R=301,L,NE]
  RewriteRule ^senioren/?$ /#teams [R=301,L,NE]
  RewriteRule ^junioren/?$ /#teams [R=301,L,NE]
  RewriteRule ^badminton-links/?$ / [R=301,L]
  RewriteRule ^links/?$ / [R=301,L]
  RewriteRule ^author/ / [R=301,L]
  RewriteRule ^category/ /#news [R=301,L,NE]
  RewriteRule ^tag/ /#news [R=301,L,NE]
  RewriteRule ^20[0-9]{2}/ /#news [R=301,L,NE]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-src https://www.openstreetmap.org; form-action 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'"
</IfModule>

<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "\.(py|pyc|pyo)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
